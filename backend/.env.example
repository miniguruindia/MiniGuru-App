# MongoDB connection string for Prisma / MongoDB
DATABASE_URL="mongodb+srv://<USER>:<PASSWORD>@cluster0.mongodb.net/miniguru?retryWrites=true&w=majority"

# JWT secrets for authentication
JWT_SECRET=your_jwt_secret_here
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=7d

# Backend runtime
PORT=8080
NODE_ENV=production
FRONTEND_URL=http://localhost:3000

# Email settings
EMAIL_ENABLED=true
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
FROM_EMAIL=admin@example.com
ADMIN_EMAIL=admin@example.com

# Payment provider credentials
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# YouTube API configuration
YOUTUBE_API_KEY=your_youtube_api_key
YOUTUBE_CLIENT_ID=your_youtube_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret
YOUTUBE_REDIRECT_URI=http://localhost:5001/auth/youtube/callback
YOUTUBE_REFRESH_TOKEN=your_youtube_refresh_token
