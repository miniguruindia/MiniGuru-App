generator client {
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  SUPERADMIN
}

enum VideoCategory {
  SHOW_PIECE
  WORKING_MODEL
  SCIENCE_EXPERIMENT
  MAGIC_SCIENCE
  LIFE_HACK
  ELECTRONICS
}

enum VideoApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ApprovalAction {
  SUBMITTED
  APPROVED
  REJECTED
  REOPENED
}

enum GuardianType {
  PARENT
  SCHOOL
  TLAB
  COMMUNITY
}

type ScoreHistory {
  time         DateTime
  updatedScore Int
}

type ChildScoreHistory {
  time         DateTime
  updatedScore Int
  reason       String?
}

type GuardianInfo {
  institutionName String?
  address         String?
  city            String?
  state           String?
  pincode         String?
  isVerified      Boolean
}

model User {
  id            String         @id @default(auto()) @map("_id") @db.ObjectId
  email         String         @unique
  passwordHash  String
  name          String
  age           Int
  role          Role           @default(USER)
  phoneNumber   String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  refreshToken  String?
  score         Int            @default(0)
  scoreHistory  ScoreHistory[]
  profilePhoto  String?
  parentName   String?
  parentPhone  String?
  guardianEmail String?
  emailVerified Boolean  @default(false)
  // ── Contact verification (email + phone), on-demand, not blocking ──────
  // Verification is never required at registration — it can be requested
  // any time by the account holder. Changing a contact that is currently
  // VERIFIED requires approval (OTP sent to the OLD verified contact, or
  // manual admin approval if that's unreachable) before it takes effect.
  // Changing an UNVERIFIED contact applies immediately — nothing to protect.
  phoneVerified            Boolean   @default(false)
  verificationOtpHash      String?
  verificationOtpExpiry    DateTime?
  verificationOtpTarget    String?   // 'email' | 'phone' — which field the pending OTP is for
  pendingEmail             String?   // new email awaiting old-contact confirmation
  pendingPhone             String?   // new phone awaiting old-contact confirmation
  contactChangeApprovalFor String?   // 'email' | 'phone' | null — set when the old contact
                                      // is unreachable and an admin must manually approve
  contactChangeRequestedAt DateTime?
  about        String?
  grade        String?
  schoolName   String?
  city         String?
  interests    String[]  @default([])
  isMentor      Boolean        @default(false)
  mentorType    GuardianType?
  guardianInfo  GuardianInfo?
  children      ChildProfile[]
  comments      Comment[]
  orders        Order[]
  likes         Like[]
  projects      Project[]
  wallet        Wallet?
  walletId      String?        @db.ObjectId
  videoViews    VideoView[]
  videoLikes    VideoLike[]
  videoComments VideoComment[]

  @@map("users")
}

model ChildProfile {
  id           String              @id @default(auto()) @map("_id") @db.ObjectId
  guardianId   String              @db.ObjectId
  guardian     User                @relation(fields: [guardianId], references: [id], onDelete: Cascade)
  name         String
  age          Int
  grade        String?
  avatar       String?
  pinHash      String
  linkedUserId String?  @db.ObjectId
  score        Int                 @default(0)
  scoreHistory ChildScoreHistory[]
  isActive     Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  projects     ChildProject[]
  videoUploads ChildVideo[]
  orders       ChildOrder[]

  @@index([guardianId])
  @@map("child_profiles")
}

model ChildProject {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  childProfileId String       @db.ObjectId
  child          ChildProfile @relation(fields: [childProfileId], references: [id], onDelete: Cascade)
  projectId      String       @db.ObjectId
  role           String       @default("OWNER")
  goinsShare     Int          @default(100)
  createdAt      DateTime     @default(now())

  @@unique([childProfileId, projectId])
  @@map("child_projects")
}

model ChildVideo {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  childProfileId String       @db.ObjectId
  child          ChildProfile @relation(fields: [childProfileId], references: [id], onDelete: Cascade)
  projectId      String?      @db.ObjectId
  youtubeUrl     String?
  title          String
  status         String       @default("pending")
  uploadedBy     String       @db.ObjectId
  createdAt      DateTime     @default(now())

  @@index([childProfileId])
  @@map("child_videos")
}

model PendingVideo {
  id                    String                    @id @default(auto()) @map("_id") @db.ObjectId
  title                 String
  description           String
  category              VideoCategory
  tags                  String[]
  localPath             String
  originalName          String?
  fileSize              Int?
  mimeType              String?
  uploadedById          String                    @db.ObjectId
  status                VideoApprovalStatus       @default(PENDING)
  approvalNotes         String?
  approvedById          String?                   @db.ObjectId
  approvedAt            DateTime?
  rejectedById          String?                   @db.ObjectId
  rejectedAt            DateTime?
  rejectionReason       String?
  youtubeVideoId        String?
  youtubeUrl            String?
  privacyStatus         String                    @default("public")
  submittedAt           DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  auditTrail            VideoApprovalAudit[]

  @@index([status])
  @@index([uploadedById])
  @@index([category])
  @@index([approvedAt])
  @@index([rejectedAt])
  @@map("pending_videos")
}

model VideoApprovalAudit {
  id                String           @id @default(auto()) @map("_id") @db.ObjectId
  pendingVideoId    String           @db.ObjectId
  pendingVideo      PendingVideo     @relation(fields: [pendingVideoId], references: [id], onDelete: Cascade)
  action            ApprovalAction
  actionById        String           @db.ObjectId
  actionByName      String?
  actionByEmail     String?
  notes             String?
  changesSummary    String?
  ipAddress         String?
  userAgent         String?
  timestamp         DateTime         @default(now())

  @@index([pendingVideoId])
  @@index([action])
  @@index([timestamp])
  @@index([actionById])
  @@map("video_approval_audits")
}

model ChildOrder {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  childProfileId String       @db.ObjectId
  child          ChildProfile @relation(fields: [childProfileId], references: [id], onDelete: Cascade)
  orderId        String       @db.ObjectId
  createdAt      DateTime     @default(now())

  @@index([childProfileId])
  @@map("child_orders")
}

model VideoView {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  videoId   String
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([videoId, userId])
  @@index([videoId])
  @@index([userId])
  @@map("video_views")
}

model VideoLike {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  videoId   String
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category  String
  createdAt DateTime @default(now())

  @@unique([videoId, userId, category])
  @@index([videoId])
  @@index([userId])
  @@map("video_likes")
}

model VideoComment {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  videoId          String
  userId           String   @db.ObjectId
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment          String
  createdAt        DateTime @default(now())
  postedToYouTube  Boolean  @default(false)
  youtubeCommentId String?

  @@index([videoId])
  @@index([userId])
  @@map("video_comments")
}

model ProjectCategory {
  id       String    @id @default(auto()) @map("_id") @db.ObjectId
  name     String    @unique
  icon     String
  imageUrl String?
  projects Project[]

  @@map("projectcategories")
}

model Project {
  id          String            @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String
  startDate   DateTime
  endDate     DateTime
  thumbnail   String
  video       Video
  materials   ProjectMaterial[]
  userId      String            @db.ObjectId
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId  String            @db.ObjectId
  category    ProjectCategory   @relation(fields: [categoryId], references: [id])
  likes       Like[]
  comments    Comment[]
  status      String            @default("pending")
  aiVerdict   String?
  aiReason    String?
  aiConfidence Float?
  aiReviewedAt DateTime?
  // Shared/group projects — additional children working on this project
  // alongside the owner (userId above). Set only at upload time (never
  // editable afterward — collaborators can only be added while planning,
  // before the video is uploaded). Goins split equally across owner +
  // all collaborators on admin approval — see approveProject().
  collaborators ProjectCollaborator[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([userId])
  @@index([categoryId])
  @@index([status])
  @@map("projects")
}

type ProjectCollaborator {
  userId String @db.ObjectId
  name   String // snapshot at time of upload, for display without an extra join
}

type Video {
  url        String
  uploadedAt String?
}

type ProjectMaterial {
  productId String  @db.ObjectId
  name      String?
  quantity  Int
}

// In-app notifications — used to REPLACE email for anything that isn't a
// literal OTP or a message to someone with no login (password reset, shop
// send-to-parent). Admin broadcasts and AI-review alerts write here instead
// of sending an email to every recipient. Surfaced via GET /users/me/notifications
// (child/mentor) and GET /admin/notifications (admin), merged with the
// existing computed comment/like feed — no separate UI needed.
model Notification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId // who sees this notification
  type      String   // 'broadcast' | 'ai_review_unsure' | 'announcement' | ...
  emoji     String   @default("🔔")
  message   String
  link      String?  // optional deep-link, e.g. a project id or admin queue path
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("notifications")
}

model Comment {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  commentedBy   User     @relation(fields: [commentedById], references: [id], onDelete: Cascade)
  commentedById String   @db.ObjectId
  content       String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId     String   @db.ObjectId

  @@unique([projectId, commentedById])
  @@index([commentedById])
  @@index([projectId])
  @@map("comments")
}

model Like {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  likedBy   User     @relation(fields: [likedById], references: [id], onDelete: Cascade)
  likedById String   @db.ObjectId
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String   @db.ObjectId

  @@unique([projectId, likedById])
  @@index([likedById])
  @@index([projectId])
  @@map("likes")
}

model ProductCategory {
  id       String    @id @default(auto()) @map("_id") @db.ObjectId
  name     String    @unique
  icon     String
  imageUrl String?
  products Product[]

  @@map("productcategories")
}

model Product {
  id               String            @id @default(auto()) @map("_id") @db.ObjectId
  name             String
  description      String
  price            Float
  inventory        Int
  categoryId       String            @db.ObjectId
  category         ProductCategory   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  images           String[]
  brand            String?
  size             String?
  howToUse         String?
  amazonUrl        String?
  flipkartUrl      String?
  sourceType       String            @default("OWN")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  projectMaterials ProjectMaterial[]

  @@index([categoryId])
  @@map("products")
}

model Order {
  id                String            @id @default(auto()) @map("_id") @db.ObjectId
  userId            String            @db.ObjectId
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  products          OrderProduct[]
  totalAmount       Float
  paymentStatus     PaymentStatus     @default(PENDING)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  transaction       Transaction       @relation(fields: [transactionId], references: [id])
  transactionId     String            @db.ObjectId @unique
  deliveryAddress   String?
  fulfillmentStatus FulfillmentStatus @default(PENDING_DISPATCH)
  courierName       String?
  trackingNumber    String?
  estimatedDelivery DateTime?
  dispatchedAt      DateTime?

  @@index([userId])
  @@map("orders")
}

type OrderProduct {
  productId String @db.ObjectId
  quantity  Int
}

enum FulfillmentStatus {
  PENDING_DISPATCH
  DISPATCHED
  DELIVERED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

model Wallet {
  id           String        @id @default(auto()) @map("_id") @db.ObjectId
  userId       String        @db.ObjectId @unique
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance      Float         @default(0.0)
  transactions Transaction[]

  @@map("wallets")
}

model Transaction {
  id        String          @id @default(auto()) @map("_id") @db.ObjectId
  walletId  String          @db.ObjectId
  wallet    Wallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)
  order     Order?
  amount    Float
  type      TransactionType
  status    PaymentStatus?
  createdAt DateTime        @default(now())

  @@index([walletId])
  @@map("transactions")
}

enum TransactionType {
  DEBIT
  CREDIT
}

model SiteContent {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@map("site_content")
}

model ContactMessage {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String
  subject   String
  message   String
  source    String    @default("app")
  status    String    @default("unread")
  repliedAt DateTime?
  repliedBy String?
  createdAt DateTime  @default(now())

  @@map("contact_messages")
}

model Material {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  seqId          Int?
  name           String
  description    String?
  imageUrl       String?
  icon           String?
  category       String
  unit           String   @default("piece")
  goinsPrice     Int
  priceEstimate  Int?
  amazonASIN     String?
  amazonUrl      String?
  showInShop     Boolean  @default(true)
  showInPlanning Boolean  @default(true)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("materials")
}

model ProductSuggestion {
  id                  String    @id @default(auto()) @map("_id") @db.ObjectId
  childName           String?
  userId              String?   @db.ObjectId
  suggestion          String
  category            String?
  requestedGoinsPrice Int?
  // pending: just submitted, not yet looked at
  // approved: admin liked it, plans to add as a real Material
  // added: admin actually created the Material — resolvedMaterialId links to it
  // rejected: admin decided not to add it — adminNotes explains why
  status             String    @default("pending")
  resolvedMaterialId String?   @db.ObjectId
  adminNotes         String?
  resolvedAt         DateTime?
  createdAt          DateTime  @default(now())

  @@map("product_suggestions")
}

model PendingRegistration {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  miniguruId    String   @unique
  childName     String
  age           Int
  grade         String?
  guardianName  String?
  guardianEmail String
  guardianPhone String?
  passwordHash  String
  otpHash       String
  otpExpiry     DateTime
  createdAt     DateTime @default(now())
  @@map("pending_registrations")
}

model VideoRating {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  videoId       String   @db.ObjectId
  raterId       String   @db.ObjectId
  creatorId     String   @db.ObjectId
  sturdy        Boolean  @default(false)
  creative      Boolean  @default(false)
  functional    Boolean  @default(false)
  resourceful   Boolean  @default(false)
  documented    Boolean  @default(false)
  isCrossSchool Boolean  @default(false)
  goinsAwarded  Int      @default(0)
  createdAt     DateTime @default(now())

  @@unique([videoId, raterId])
  @@map("video_ratings")
}

model Happening {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  title           String
  description     String
  date            DateTime
  city            String?
  schoolName      String?   // auto-filled from submitter's guardianInfo.institutionName — never typed manually
  emoji           String    @default("🏫")
  tag             String    @default("Update")   // NEW / UPCOMING / MILESTONE / AWARD / PAST
  tagColor        String?
  imageUrl        String?
  status          String    @default("PENDING")  // PENDING | APPROVED | REJECTED
  submittedById   String?   @db.ObjectId          // null = admin-authored (auto-approved)
  submittedByName String?
  approvedById    String?   @db.ObjectId
  approvedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
  @@index([submittedById])
  @@map("happenings")
}

model Challenge {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  title           String
  description     String
  category        String
  categoryEmoji   String?
  difficulty      String    @default("Medium")
  goinsReward     Int       @default(100)
  endDate         DateTime
  participants    Int       @default(0)
  color           String?
  lifecycleStatus String    @default("upcoming")  // ongoing | upcoming | past — DISPLAY status
  status          String    @default("PENDING")   // PENDING | APPROVED | REJECTED — MODERATION status
  audience        String    @default("ALL")       // ALL | OWN_SCHOOL
  restrictedToUserId String? @db.ObjectId          // set when audience=OWN_SCHOOL — the submitting teacher/school's own User.id
  submittedById   String?   @db.ObjectId           // null = admin-authored (auto-approved, always ALL)
  submittedByName String?
  approvedById    String?   @db.ObjectId
  approvedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
  @@index([audience])
  @@index([submittedById])
  @@map("challenges")
}

model GoinTopUpRequest {
  id                  String    @id @default(auto()) @map("_id") @db.ObjectId
  requesterId         String    @db.ObjectId
  requesterName       String
  amount              Int
  reason              String?
  projectDraftContext String?
  status              String    @default("PENDING")
  decidedById         String?   @db.ObjectId
  decidedByRole       String?
  decidedAt           DateTime?
  denialReason        String?
  createdAt           DateTime  @default(now())

  @@index([requesterId])
  @@index([status])
  @@map("goin_topup_requests")
}