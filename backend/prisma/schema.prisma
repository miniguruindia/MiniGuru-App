generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  SUPERADMIN
}

enum GuardianType {
  PARENT
  SCHOOL
  TLAB
  COMMUNITY
}

type ScoreHistory {
  time         DateTime
  updatedScore Int
}

type ChildScoreHistory {
  time         DateTime
  updatedScore Int
  reason       String?
}

type GuardianInfo {
  institutionName String?
  address         String?
  city            String?
  state           String?
  pincode         String?
  isVerified      Boolean
}

model User {
  id            String         @id @default(auto()) @map("_id") @db.ObjectId
  email         String         @unique
  passwordHash  String
  name          String
  age           Int
  role          Role           @default(USER)
  phoneNumber   String         @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  refreshToken  String?
  score         Int            @default(0)
  scoreHistory  ScoreHistory[]
  profilePhoto  String?
  isMentor      Boolean        @default(false)
  mentorType    GuardianType?
  guardianInfo  GuardianInfo?
  children      ChildProfile[]
  comments      Comment[]
  orders        Order[]
  likes         Like[]
  projects      Project[]
  wallet        Wallet?
  walletId      String?        @db.ObjectId
  videoViews    VideoView[]
  videoLikes    VideoLike[]
  videoComments VideoComment[]

  @@map("users")
}

model ChildProfile {
  id           String              @id @default(auto()) @map("_id") @db.ObjectId
  guardianId   String              @db.ObjectId
  guardian     User                @relation(fields: [guardianId], references: [id], onDelete: Cascade)
  name         String
  age          Int
  grade        String?
  avatar       String?
  pinHash      String
  score        Int                 @default(0)
  scoreHistory ChildScoreHistory[]
  isActive     Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  projects     ChildProject[]
  videoUploads ChildVideo[]
  orders       ChildOrder[]

  @@index([guardianId])
  @@map("child_profiles")
}

model ChildProject {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  childProfileId String       @db.ObjectId
  child          ChildProfile @relation(fields: [childProfileId], references: [id], onDelete: Cascade)
  projectId      String       @db.ObjectId
  role           String       @default("OWNER")
  goinsShare     Int          @default(100)
  createdAt      DateTime     @default(now())

  @@unique([childProfileId, projectId])
  @@map("child_projects")
}

model ChildVideo {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  childProfileId String       @db.ObjectId
  child          ChildProfile @relation(fields: [childProfileId], references: [id], onDelete: Cascade)
  projectId      String?      @db.ObjectId
  youtubeUrl     String?
  title          String
  status         String       @default("pending")
  uploadedBy     String       @db.ObjectId
  createdAt      DateTime     @default(now())

  @@index([childProfileId])
  @@map("child_videos")
}

model ChildOrder {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  childProfileId String       @db.ObjectId
  child          ChildProfile @relation(fields: [childProfileId], references: [id], onDelete: Cascade)
  orderId        String       @db.ObjectId
  createdAt      DateTime     @default(now())

  @@index([childProfileId])
  @@map("child_orders")
}

model VideoView {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  videoId   String
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([videoId, userId])
  @@index([videoId])
  @@index([userId])
  @@map("video_views")
}

model VideoLike {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  videoId   String
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category  String
  createdAt DateTime @default(now())

  @@unique([videoId, userId, category])
  @@index([videoId])
  @@index([userId])
  @@map("video_likes")
}

model VideoComment {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  videoId          String
  userId           String   @db.ObjectId
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment          String
  createdAt        DateTime @default(now())
  postedToYouTube  Boolean  @default(false)
  youtubeCommentId String?

  @@index([videoId])
  @@index([userId])
  @@map("video_comments")
}

model ProjectCategory {
  id       String    @id @default(auto()) @map("_id") @db.ObjectId
  name     String    @unique
  icon     String
  imageUrl String?
  projects Project[]

  @@map("projectcategories")
}

model Project {
  id          String            @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String
  startDate   DateTime
  endDate     DateTime
  thumbnail   String
  video       Video
  materials   ProjectMaterial[]
  userId      String            @db.ObjectId
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId  String            @db.ObjectId
  category    ProjectCategory   @relation(fields: [categoryId], references: [id])
  likes       Like[]
  comments    Comment[]
  status      String            @default("pending")
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([userId])
  @@index([categoryId])
  @@index([status])
  @@map("projects")
}

type Video {
  url        String
  uploadedAt String?
}

type ProjectMaterial {
  productId String  @db.ObjectId
  name      String?
  quantity  Int
}

model Comment {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  commentedBy   User     @relation(fields: [commentedById], references: [id], onDelete: Cascade)
  commentedById String   @db.ObjectId
  content       String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId     String   @db.ObjectId

  @@unique([projectId, commentedById])
  @@index([commentedById])
  @@index([projectId])
  @@map("comments")
}

model Like {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  likedBy   User     @relation(fields: [likedById], references: [id], onDelete: Cascade)
  likedById String   @db.ObjectId
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String   @db.ObjectId

  @@unique([projectId, likedById])
  @@index([likedById])
  @@index([projectId])
  @@map("likes")
}

model ProductCategory {
  id       String    @id @default(auto()) @map("_id") @db.ObjectId
  name     String    @unique
  icon     String
  imageUrl String?
  products Product[]

  @@map("productcategories")
}

model Product {
  id               String            @id @default(auto()) @map("_id") @db.ObjectId
  name             String
  description      String
  price            Float
  inventory        Int
  categoryId       String            @db.ObjectId
  category         ProductCategory   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  images           String[]
  brand            String?
  size             String?
  howToUse         String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  projectMaterials ProjectMaterial[]

  @@index([categoryId])
  @@map("products")
}

model Order {
  id                String            @id @default(auto()) @map("_id") @db.ObjectId
  userId            String            @db.ObjectId
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  products          OrderProduct[]
  totalAmount       Float
  paymentStatus     PaymentStatus     @default(PENDING)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  transaction       Transaction       @relation(fields: [transactionId], references: [id])
  transactionId     String            @db.ObjectId @unique
  deliveryAddress   String?
  fulfillmentStatus FulfillmentStatus @default(PENDING_DISPATCH)
  courierName       String?
  trackingNumber    String?
  estimatedDelivery DateTime?
  dispatchedAt      DateTime?

  @@index([userId])
  @@map("orders")
}

type OrderProduct {
  productId String @db.ObjectId
  quantity  Int
}

enum FulfillmentStatus {
  PENDING_DISPATCH
  DISPATCHED
  DELIVERED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

model Wallet {
  id           String        @id @default(auto()) @map("_id") @db.ObjectId
  userId       String        @db.ObjectId @unique
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance      Float         @default(0.0)
  transactions Transaction[]

  @@map("wallets")
}

model Transaction {
  id        String          @id @default(auto()) @map("_id") @db.ObjectId
  walletId  String          @db.ObjectId
  wallet    Wallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)
  order     Order?
  amount    Float
  type      TransactionType
  status    PaymentStatus?
  createdAt DateTime        @default(now())

  @@index([walletId])
  @@map("transactions")
}

enum TransactionType {
  DEBIT
  CREDIT
}

model SiteContent {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@map("site_content")
}

model ContactMessage {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String
  subject   String
  message   String
  source    String    @default("app")
  status    String    @default("unread")
  repliedAt DateTime?
  repliedBy String?
  createdAt DateTime  @default(now())

  @@map("contact_messages")
}
